rules_version = '2';

// FIREBASE STORAGE SECURITY RULES
// Explicitly allowing public list and get access for the gallery.

service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // allow read covers both 'get' and 'list'
      allow read: if true;
      allow write: if request.auth != null;
    }
    // Deployment trigger version: 1.2.0
  }
}