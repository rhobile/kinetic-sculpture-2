rules_version = '2';

// FIREBASE STORAGE SECURITY RULES
// 
// Updated to use the new ks-images and ks-videos folder structure.
// 
// Public Read: All users can view media in ks-images and ks-videos.
// Restricted Write: Uploads/Deletes are restricted to authenticated users.

service firebase.storage {
  match /b/{bucket}/o {
    
    // Rules for sculpture images in the new ks-images folder
    match /ks-images/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Rules for sculpture videos in the new ks-videos folder
    match /ks-videos/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
