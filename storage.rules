rules_version = '2';

// FIREBASE STORAGE SECURITY RULES
// 
// Optimized for the Rhobile Kinetic Sculptures project.
// 
// Public Read: Allows unauthenticated users to view images and videos in the gallery.
// Restricted Write: Management operations (upload/delete) require authentication.

service firebase.storage {
  match /b/{bucket}/o {
    
    // Explicitly allow reading and listing the content of ks-images
    match /ks-images {
      allow read: if true;
      allow write: if request.auth != null;
      
      // Allow access to all files within the folder
      match /{allPaths=**} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }
    
    // Explicitly allow reading and listing the content of ks-videos
    match /ks-videos {
      allow read: if true;
      allow write: if request.auth != null;
      
      // Allow access to all files within the folder
      match /{allPaths=**} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }
    
    // Default deny for everything else to maintain security
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
