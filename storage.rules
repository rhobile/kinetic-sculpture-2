rules_version = '2';

// FIREBASE STORAGE SECURITY RULES
// 
// Optimized for the Rhobile Kinetic Sculptures project.
// 
// Public Read: Allows anyone to view and list images and videos in the ks- folders.
// Restricted Write: Management operations (upload/delete) require authentication.

service firebase.storage {
  match /b/{bucket}/o {
    
    // Rules for Sculpture Images
    match /ks-images {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /ks-images/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Rules for Sculpture Videos
    match /ks-videos {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /ks-videos/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Default deny for everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}