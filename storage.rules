rules_version = '2';

// FIREBASE STORAGE SECURITY RULES
service firebase.storage {
  match /b/{bucket}/o {
    
    function isAdmin() {
      return request.auth != null && (
        request.auth.uid == 'ge6KSJEZKFXsNZerEbXseOR2vSS2' || 
        request.auth.token.email == 'rhobile@gmail.com' ||
        request.auth.uid == 'yuFerZOVxgXYUM4GRhlXBrxCSNt1'
      );
    }

    match /{allPaths=**} {
      // Publicly readable for the gallery
      allow read: if true;
      // Protected write access
      allow write: if isAdmin();
    }
    // Deployment trigger version: 1.3.0
  }
}