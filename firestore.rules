rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Explicitly allow public read/list for all primary collections used by the app.
    // This ensures that collection-level queries (method: list) work correctly.
    
    match /videos/{allPaths=**} {
      allow read, list: if true;
      allow write: if request.auth != null;
    }
    
    match /news/{allPaths=**} {
      allow read, list: if true;
      allow write: if request.auth != null;
    }
    
    match /pages/{allPaths=**} {
      allow read, list: if true;
      allow write: if request.auth != null;
    }

    // Default catch-all rule for any other potential documents.
    match /{document=**} {
      allow read, list: if true;
      allow write: if request.auth != null;
    }
    
    // Deployment trigger version: 1.3.1 (Force re-propagation)
  }
}