
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Rules for videos collection
    // Allows anyone to read individual videos and list the collection (queries).
    // Requires authentication for any write operations (create, update, delete).
    match /videos/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Rules for news collection
    // Allows public reading of news updates.
    // Requires authentication for managing news.
    match /news/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Rules for pages collection
    // Allows public reading of static page content (about, contact, sidebar).
    // Requires authentication for editing page content.
    match /pages/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
