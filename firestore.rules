rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow public read access to all documents in the database.
    // This supports the public gallery, news, and pages.
    match /{document=**} {
      allow read, list: if true;
      // Writing still requires authentication (anonymous or otherwise).
      allow write: if request.auth != null;
    }
    
    // Deployment trigger version: 1.1.4
  }
}