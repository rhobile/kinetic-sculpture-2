rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Explicitly allow public read and list access for primary collections.
    // This handles both direct document access (get) and collection queries (list).
    
    match /videos {
      allow read, list: if true;
      match /{allPaths=**} {
        allow read, list: if true;
        allow write: if request.auth != null;
      }
    }
    
    match /news {
      allow read, list: if true;
      match /{allPaths=**} {
        allow read, list: if true;
        allow write: if request.auth != null;
      }
    }
    
    match /pages {
      allow read, list: if true;
      match /{allPaths=**} {
        allow read, list: if true;
        allow write: if request.auth != null;
      }
    }

    // Global fallback for safety
    match /{document=**} {
      allow read, list: if true;
      allow write: if request.auth != null;
    }
    
    // Deployment trigger version: 1.6.4 (Enforcing recursive wildcard list permission)
  }
}