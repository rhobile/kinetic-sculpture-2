rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow public read and list access for all primary collections.
    // This ensures the gallery and dashboard can load data for any visitor.
    match /{document=**} {
      allow read, list: if true;
      allow write: if request.auth != null;
    }
    
    // Deployment trigger version: 1.5.0 (Global permissive read/list)
  }
}