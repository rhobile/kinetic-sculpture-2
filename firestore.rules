rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow public read and list access to all public collections
    match /videos/{videoId} {
      allow read, list: if true;
      allow write: if request.auth != null;
    }
    
    match /news/{newsId} {
      allow read, list: if true;
      allow write: if request.auth != null;
    }
    
    match /pages/{pageId} {
      allow read, list: if true;
      allow write: if request.auth != null;
    }

    // Global fallback for queries and subcollections
    match /{document=**} {
      allow read, list: if true;
      allow write: if request.auth != null;
    }
    
    // Deployment trigger version: 2.4.1
  }
}