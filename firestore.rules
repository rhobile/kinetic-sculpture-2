rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow public read and list access to all documents.
    // This ensures that collection-wide queries for the gallery and news work without permission errors.
    match /{document=**} {
      allow read, list: if true;
      // Allow writes for authenticated users (including anonymous sessions used by the dashboard).
      allow write: if request.auth != null;
    }
    
    // Deployment trigger version: 1.1.9
  }
}