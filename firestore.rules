rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global fallback for Rhobile Kinetic Sculptures
    // This allows public read/list access to all content (videos, news, pages)
    // while restricting write access to authenticated administrators.
    match /{document=**} {
      allow read, list: if true;
      allow write: if request.auth != null;
    }
    
    // Deployment trigger version: 2.3.0 (Enforcing global public read/list)
  }
}