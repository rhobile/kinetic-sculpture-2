
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /videos/{videoId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /news/{newsId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /pages/{pageId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
